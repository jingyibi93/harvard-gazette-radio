{
  "rewrites": [
    {
      "source": "/data/:path*",
      "destination": "https://wnifqbhtsbqafbkrvgxb.supabase.co/storage/v1/object/public/harvard-radio/:path*"
    }
  ],
  "headers": [
    {
      "source": "/data/episodes/(latest|index).json",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, s-maxage=60, must-revalidate"
        }
      ]
    },
    {
      "source": "/data/images/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400, s-maxage=604800, stale-while-revalidate=86400"
        }
      ]
    },
    {
      "source": "/data/audio/(.*).m4a",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400, s-maxage=604800, stale-while-revalidate=86400"
        }
      ]
    },
    {
      "source": "/data/audio/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=300, s-maxage=3600, stale-while-revalidate=3600"
        }
      ]
    },
    {
      "source": "/data/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        }
      ]
    }
  ]
}
